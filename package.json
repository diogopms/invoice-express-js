{
  "name": "@diogopms/invoice-express-js",
  "version": "1.0.13",
  "description": "JavaScript client for the Invoice Express API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "node generate.mjs",
    "generate:check": "pnpm run generate && git diff --exit-code -- src",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc -p tsconfig.examples.json",
    "pretest": "pnpm run build",
    "test": "node --test",
    "pretest:live": "pnpm run build",
    "test:live": "node scripts/live-check.cjs",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.js\" \"examples/**/*.ts\" \"scripts/**/*.cjs\" \"generate.mjs\" \"*.{json,yaml}\"",
    "lint": "prettier --check \"src/**/*.ts\" \"test/**/*.js\" \"examples/**/*.ts\" \"scripts/**/*.cjs\" \"generate.mjs\" \"*.{json,yaml}\"",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "invoice-express-js",
    "invoicexpress",
    "typescript",
    "javascript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diogopms/invoice-express-js.git"
  },
  "homepage": "https://github.com/diogopms/invoice-express-js#readme",
  "bugs": "https://github.com/diogopms/invoice-express-js/issues",
  "author": "Diogo Serrano",
  "license": "ISC",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.52.11",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.11.0+sha512.0a203ffaed5a3f63242cd064c8fb5892366c103e328079318f78062f24ea8c9d50bc6a47aa3567cabefd824d170e78fa2745ed1f16b132e16436146b7688f19b"
}
